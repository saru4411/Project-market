# BuyEway Enterprise Deployment – Environment Template
# -----------------------------------------------------------------------------
# Copy this file to '.env' and modify values as needed for your target platform.
# For local Docker Compose execution, the default values below are recommended.
# -----------------------------------------------------------------------------

# 1. Database PostgreSQL Sandboxing Credentials
POSTGRES_DB=buyeway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=inditrade_secure_db_pass_2026_xYz987

# 2. Asymmetric Cryptography & JWT Security Tokens
JWT_SECRET=inditrade_jwt_secret_key_2026_super_secure_sha256_hash_value

# 3. Dynamic Database Routing URL
# For local Docker:
DATABASE_URL=postgres://postgres:inditrade_secure_db_pass_2026_xYz987@buyeway-postgres:5432/buyeway
# For cloud/managed databases (e.g. AWS RDS / GCP Cloud SQL), replace with connection string:
# DATABASE_URL=postgres://user:pass@host:port/dbname
DATABASE_SSL=false

# 4. Service Ports & Internal Discovery Networking
PORT=8000

# 5. External Sourcing APIs & CORS Control (Browser-side)
# Local development ports:
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_COMPUTE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost,http://127.0.0.1:3000,http://127.0.0.1

# 6. Internal Service Networking (Inside Docker network)
COMPUTE_SERVICE_URL=http://go-compute:8080
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# CLOUD DEPLOYMENT SPECIFICATION EXAMPLES (PLUG & PLAY)
# -----------------------------------------------------------------------------
# When taking BuyEway online (e.g., Next.js on Vercel, Node/Go on Railway):
#
# A. Next.js Storefront (Vercel):
#    Set the following in the Vercel Dashboard:
#    NEXT_PUBLIC_GATEWAY_URL=https://api.yourdomain.com/api/v1
#    NEXT_PUBLIC_COMPUTE_URL=https://compute.yourdomain.com
#
# B. Node.js Gateway (Railway/Render):
#    ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
#    DATABASE_URL=postgresql://your-cloud-db-url
#    DATABASE_SSL=true
#    JWT_SECRET=your-random-generated-production-jwt-secret
#    COMPUTE_SERVICE_URL=https://compute.yourdomain.com
#    REDIS_URL=rediss://your-cloud-redis-url
# -----------------------------------------------------------------------------
